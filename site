    <script>
        // Countdown Timer (30 days from now)
        const launchDate = new Date();
        launchDate.setDate(launchDate.getDate() + 30);
        
        function updateCountdown() {
            const now = new Date().getTime();
            const distance = launchDate.getTime() - now;
            
            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((distance % (1000 * 60)) / 1000);
            
            document.getElementById('days').textContent = String(days).padStart(2, '0');
            document.getElementById('hours').textContent = String(hours).padStart(2, '0');
            document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
            document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
            
            if (distance < 0) {
                clearInterval(countdownTimer);
                document.querySelector('.countdown-container').innerHTML = '<h2 style="color: var(--accent-green);">We\'re Live!</h2>';
            }
        }
        
        const countdownTimer = setInterval(updateCountdown, 1000);
        updateCountdown();

        // Pricing Toggle Functionality
        document.querySelectorAll('.toggle-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const plan = this.dataset.plan;
                const type = this.dataset.type;
                const card = this.closest('.pricing-card');
                const priceDisplay = card.querySelector('.price-amount');
                const priceLabel = card.querySelector('.price-label');
                const toggleBtns = card.querySelectorAll('.toggle-btn');
                
                // Remove active class from all buttons in this card
                toggleBtns.forEach(b => b.classList.remove('active'));
                // Add active class to clicked button
                this.classList.add('active');
                
                // Define pricing structure
                const pricing = {
                    '50k': {
                        standard: { price: '$34.99', label: '+ $69.99 Activation' },
                        noactivation: { price: '$109.99', label: 'No Activation Fee' }
                    },
                    '100k': {
                        standard: { price: '$79.99', label: '+ $139.98 Activation' },
                        noactivation: { price: '$149.99', label: 'No Activation Fee' }
                    },
                    '150k': {
                        standard: { price: '$119.99', label: '+ $209.97 Activation' },
                        noactivation: { price: '$189.99', label: 'No Activation Fee' }
                    }
                };
                
                // Update price display
                priceDisplay.textContent = pricing[plan][type].price;
                priceLabel.textContent = pricing[plan][type].label;
            });
        });

        // Update button countdowns
        function updateButtonCountdowns() {
            const now = new Date().getTime();
            const distance = launchDate.getTime() - now;
            
            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            
            document.querySelectorAll('.btn-days').forEach(el => {
                el.textContent = String(days).padStart(2, '0');
            });
            document.querySelectorAll('.btn-hours').forEach(el => {
                el.textContent = String(hours).padStart(2, '0');
            });
            document.querySelectorAll('.btn-minutes').forEach(el => {
                el.textContent = String(minutes).padStart(2, '0');
            });
        }

        // Call button countdown update with main countdown
        const originalUpdateCountdown = updateCountdown;
        updateCountdown = function() {
            originalUpdateCountdown();
            updateButtonCountdowns();
        };
        
        updateButtonCountdowns();

        // Animated Counter Function
        function animateCounter(element, target, duration = 2000, isDecimal = false) {
            const start = 0;
            const increment = target / (duration / 16);
            let current = start;
            
            const timer = setInterval(() => {
                current += increment;
                if (current >= target) {
                    current = target;
                    clearInterval(timer);
                }
                
                if (isDecimal) {
                    element.textContent = current.toLocaleString('en-US', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                } else {
                    element.textContent = Math.floor(current).toLocaleString();
                }
            }, 16);
        }

        // Intersection Observer for triggering animations when elements are visible
        const observerOptions = {
            threshold: 0.3,
            rootMargin: '0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting && !entry.target.classList.contains('animated')) {
                    entry.target.classList.add('animated');
                    
                    // Animate stat numbers
                    if (entry.target.classList.contains('stat-card')) {
                        const numberElement = entry.target.querySelector('.stat-number');
                        const text = numberElement.textContent;
                        
                        if (text.includes('$')) {
                            const value = parseInt(text.replace(/\D/g, ''));
                            numberElement.textContent = '$';
                            const span = document.createElement('span');
                            numberElement.appendChild(span);
                            animateCounter(span, value, 2000);
                            setTimeout(() => {
                                numberElement.innerHTML = '$' + value + 'M+';
                            }, 2000);
                        } else if (text.includes('+')) {
                            const value = parseInt(text.replace(/\D/g, ''));
                            animateCounter(numberElement, value, 2000);
                            setTimeout(() => {
                                numberElement.textContent = value.toLocaleString() + '+';
                            }, 2000);
                        } else {
                            // For 24/7
                            numberElement.style.opacity = '0';
                            setTimeout(() => {
                                numberElement.style.transition = 'opacity 0.5s ease';
                                numberElement.style.opacity = '1';
                            }, 500);
                        }
                    }
                    
                    // Animate pricing card values
                    if (entry.target.classList.contains('pricing-card')) {
                        const featureValues = entry.target.querySelectorAll('.feature-value');
                        featureValues.forEach((value, index) => {
                            const text = value.textContent.trim();
                            if (text.startsWith('$')) {
                                const numValue = parseFloat(text.replace(/[$,]/g, ''));
                                value.textContent = '$0';
                                setTimeout(() => {
                                    const tempSpan = document.createElement('span');
                                    value.textContent = '';
                                    value.appendChild(tempSpan);
                                    tempSpan.textContent = '$';
                                    const numberSpan = document.createElement('span');
                                    value.appendChild(numberSpan);
                                    animateCounter(numberSpan, numValue, 1500, text.includes('.'));
                                }, index * 100);
                            } else {
                                const numValue = parseInt(text);
                                value.textContent = '0';
                                setTimeout(() => {
                                    animateCounter(value, numValue, 1500);
                                }, index * 100);
                            }
                        });

                        // Animate price display
                        const priceAmount = entry.target.querySelector('.price-amount');
                        if (priceAmount) {
                            const originalPrice = priceAmount.textContent;
                            const numValue = parseFloat(originalPrice.replace(/[$,]/g, ''));
                            priceAmount.textContent = '$0.00';
                            setTimeout(() => {
                                priceAmount.textContent = '$';
                                const numberSpan = document.createElement('span');
                                priceAmount.appendChild(numberSpan);
                                animateCounter(numberSpan, numValue, 1500, true);
                                setTimeout(() => {
                                    priceAmount.textContent = originalPrice;
                                }, 1500);
                            }, 300);
                        }
                    }

                    // Animate Why Us cards
                    if (entry.target.classList.contains('why-us-card')) {
                        entry.target.classList.add('visible');
                        
                        // Animate the stat number in the card
                        const statNumber = entry.target.querySelector('.why-us-stat-number');
                        if (statNumber && !statNumber.classList.contains('unlimited')) {
                            const target = parseInt(statNumber.dataset.target);
                            setTimeout(() => {
                                animateCounter(statNumber, target, 2000);
                            }, 300);
                        }
                    }

                    // Animate trust indicators
                    if (entry.target.classList.contains('trust-item')) {
                        entry.target.classList.add('visible');
                    }
                }
            });
        }, observerOptions);

        // Observe all elements that need animation
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.stat-card').forEach(card => observer.observe(card));
            document.querySelectorAll('.pricing-card').forEach(card => observer.observe(card));
            document.querySelectorAll('.why-us-card').forEach(card => observer.observe(card));
            document.querySelectorAll('.trust-item').forEach((item, index) => {
                item.style.animationDelay = `${index * 0.1}s`;
                observer.observe(item);
            });
        });

        // Smooth scrolling for navigation links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</body>
</html>
