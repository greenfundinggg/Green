<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Green | Elite Trading Prop Firm</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0a0a0a;
            --bg-card: #141414;
            --text-primary: #ffffff;
            --text-secondary: #a0a0a0;
            --accent-green: #00BF63;
            --accent-green-glow: rgba(0, 191, 99, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-primary);
            overflow-x: hidden;
            line-height: 1.6;
            font-size: 18px;
        }

        /* Animated background grid */
        .bg-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 191, 99, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0, 191, 99, 0.02) 1px, transparent 1px);
            background-size: 60px 60px;
            z-index: 0;
            animation: gridMove 20s linear infinite;
        }

        @keyframes gridMove {
            0% { transform: translateY(0); }
            100% { transform: translateY(60px); }
        }

        .bg-gradient {
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle at 50% 50%, rgba(0, 191, 99, 0.04) 0%, transparent 50%);
            animation: rotate 40s linear infinite;
            z-index: 0;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Header */
        header {
            position: relative;
            z-index: 100;
            padding: 1.5rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            backdrop-filter: blur(10px);
            background: rgba(10, 10, 10, 0.8);
            border-bottom: 1px solid rgba(0, 191, 99, 0.15);
        }

        .logo {
            font-size: 1.8rem;
            font-weight: 800;
            letter-spacing: 0.05em;
            color: var(--accent-green);
            text-shadow: 0 0 20px var(--accent-green-glow);
        }

        nav {
            display: flex;
            gap: 2.5rem;
        }

        nav a {
            color: var(--text-secondary);
            text-decoration: none;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }

        nav a:hover {
            color: var(--accent-green);
        }

        nav a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--accent-green);
            transition: width 0.3s ease;
        }

        nav a:hover::after {
            width: 100%;
        }

        /* Hero Section */
        .hero {
            position: relative;
            z-index: 10;
            padding: 8rem 5% 6rem;
            text-align: center;
        }

        .coming-soon-badge {
            display: inline-block;
            padding: 0.8rem 2rem;
            background: linear-gradient(135deg, var(--accent-green), #00ff7f);
            color: var(--bg-dark);
            font-weight: 800;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            border-radius: 50px;
            margin-bottom: 2rem;
            animation: pulse 2s ease-in-out infinite;
            box-shadow: 0 0 30px var(--accent-green-glow);
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .countdown-container {
            margin: 3rem auto;
            max-width: 700px;
        }

        .countdown-label {
            font-size: 1.2rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 1.5rem;
            font-weight: 600;
        }

        .countdown-timer {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .countdown-item {
            background: var(--bg-card);
            border: 2px solid rgba(0, 191, 99, 0.2);
            border-radius: 12px;
            padding: 1.5rem 2rem;
            min-width: 120px;
            transition: all 0.3s ease;
        }

        .countdown-item:hover {
            border-color: var(--accent-green);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px var(--accent-green-glow);
        }

        .countdown-number {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--accent-green);
            font-family: 'JetBrains Mono', monospace;
            line-height: 1;
            margin-bottom: 0.5rem;
        }

        .countdown-text {
            font-size: 0.9rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 600;
        }

        .hero h1 {
            font-size: 5.5rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1.5rem;
            letter-spacing: -0.03em;
            animation: fadeInUp 0.8s ease;
        }

        .hero .highlight {
            color: var(--accent-green);
            position: relative;
            display: inline-block;
        }

        .hero .highlight::after {
            content: '';
            position: absolute;
            bottom: 0.2rem;
            left: 0;
            width: 100%;
            height: 0.4rem;
            background: var(--accent-green);
            opacity: 0.3;
            z-index: -1;
        }

        .hero p {
            font-size: 1.3rem;
            color: var(--text-secondary);
            max-width: 700px;
            margin: 0 auto 3rem;
            animation: fadeInUp 0.8s ease 0.2s backwards;
        }

        /* Stats Section */
        .stats {
            position: relative;
            z-index: 10;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
            padding: 4rem 5%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .stat-card {
            text-align: center;
            padding: 2rem;
            background: var(--bg-card);
            border: 1px solid rgba(0, 191, 99, 0.1);
            border-radius: 12px;
            transition: all 0.3s ease;
            animation: fadeInUp 0.8s ease backwards;
        }

        .stat-card:nth-child(1) { animation-delay: 0.5s; }
        .stat-card:nth-child(2) { animation-delay: 0.6s; }
        .stat-card:nth-child(3) { animation-delay: 0.7s; }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--accent-green);
            box-shadow: 0 10px 40px rgba(0, 191, 99, 0.15);
        }

        .stat-number {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--accent-green);
            font-family: 'JetBrains Mono', monospace;
            margin-bottom: 0.5rem;
        }

        .stat-label {
            color: var(--text-secondary);
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* Why Us Section */
        .why-us {
            position: relative;
            z-index: 10;
            padding: 8rem 5%;
            background: linear-gradient(180deg, transparent, rgba(0, 191, 99, 0.01), transparent);
        }

        .why-us-content {
            max-width: 1400px;
            margin: 0 auto;
        }

        .why-us-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2.5rem;
            margin: 4rem 0;
        }

        .why-us-card {
            background: var(--bg-card);
            border: 2px solid rgba(0, 191, 99, 0.1);
            border-radius: 16px;
            padding: 3rem;
            position: relative;
            overflow: hidden;
            transition: all 0.5s ease;
            opacity: 0;
            transform: translateY(30px);
        }

        .why-us-card.visible {
            animation: slideInUp 0.6s ease forwards;
        }

        @keyframes slideInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .why-us-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, transparent, rgba(0, 191, 99, 0.05));
            opacity: 0;
            transition: opacity 0.5s ease;
            pointer-events: none;
        }

        .why-us-card:hover::before {
            opacity: 1;
        }

        .why-us-card:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: var(--accent-green);
            box-shadow: 0 20px 60px rgba(0, 191, 99, 0.2);
        }

        .why-us-icon {
            width: 80px;
            height: 80px;
            background: rgba(0, 191, 99, 0.1);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1.5rem;
            border: 2px solid rgba(0, 191, 99, 0.3);
            transition: all 0.3s ease;
        }

        .why-us-icon svg {
            width: 40px;
            height: 40px;
            color: var(--accent-green);
            transition: all 0.3s ease;
        }

        .why-us-card:hover .why-us-icon {
            background: rgba(0, 191, 99, 0.2);
            border-color: var(--accent-green);
            transform: scale(1.1);
        }

        .why-us-card:hover .why-us-icon svg {
            transform: scale(1.1);
        }

        .why-us-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--text-primary);
        }

        .why-us-description {
            color: var(--text-secondary);
            line-height: 1.8;
            margin-bottom: 2rem;
            font-size: 1.05rem;
        }

        .why-us-description strong {
            color: var(--text-primary);
            font-weight: 700;
        }

        .why-us-stat {
            display: flex;
            align-items: baseline;
            gap: 0.5rem;
            padding: 1.5rem;
            background: rgba(0, 191, 99, 0.05);
            border-radius: 12px;
            border: 1px solid rgba(0, 191, 99, 0.2);
        }

        .why-us-stat-number {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--accent-green);
            font-family: 'JetBrains Mono', monospace;
            line-height: 1;
        }

        .why-us-stat-number.unlimited {
            font-size: 4rem;
        }

        .why-us-stat-label {
            color: var(--text-secondary);
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 600;
        }

        .trust-indicators {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
            margin-top: 5rem;
            padding: 3rem;
            background: var(--bg-card);
            border-radius: 16px;
            border: 2px solid rgba(0, 191, 99, 0.2);
        }

        .trust-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            opacity: 0;
            transform: translateX(-20px);
        }

        .trust-item.visible {
            animation: slideInRight 0.6s ease forwards;
        }

        @keyframes slideInRight {
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .trust-icon {
            width: 50px;
            height: 50px;
            background: var(--accent-green);
            color: var(--bg-dark);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.3s ease;
        }

        .trust-icon svg {
            width: 24px;
            height: 24px;
            color: var(--bg-dark);
        }

        .trust-item:hover .trust-icon {
            transform: scale(1.1);
            box-shadow: 0 8px 20px var(--accent-green-glow);
        }

        .trust-text {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-primary);
        }

        /* Funding Plans Section */
        .funding-section {
            position: relative;
            z-index: 10;
            padding: 6rem 5%;
        }

        .section-title {
            text-align: center;
            font-size: 3.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            letter-spacing: -0.02em;
        }

        .section-subtitle {
            text-align: center;
            color: var(--text-secondary);
            font-size: 1.2rem;
            margin-bottom: 4rem;
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2.5rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .pricing-card {
            background: var(--bg-card);
            border: 2px solid rgba(0, 191, 99, 0.15);
            border-radius: 16px;
            padding: 3rem 2.5rem;
            position: relative;
            overflow: hidden;
            transition: all 0.4s ease;
            animation: fadeInUp 1s ease backwards;
        }

        .pricing-card:nth-child(1) { animation-delay: 0.8s; }
        .pricing-card:nth-child(2) { 
            animation-delay: 0.9s;
            border-color: var(--accent-green);
            transform: scale(1.05);
        }
        .pricing-card:nth-child(3) { animation-delay: 1s; }

        .pricing-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
            opacity: 0;
            transition: opacity 0.4s ease;
        }

        .pricing-card:hover::before {
            opacity: 1;
        }

        .pricing-card:hover {
            transform: translateY(-10px) scale(1.02);
            border-color: var(--accent-green);
            box-shadow: 0 20px 60px rgba(0, 191, 99, 0.2);
        }

        .pricing-card.featured {
            border-color: var(--accent-green);
            box-shadow: 0 20px 60px rgba(0, 191, 99, 0.15);
        }

        .popular-badge {
            position: absolute;
            top: 20px;
            right: -35px;
            background: var(--accent-green);
            color: var(--bg-dark);
            padding: 0.5rem 3rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            transform: rotate(45deg);
            box-shadow: 0 4px 10px rgba(0, 191, 99, 0.3);
        }

        .plan-name {
            font-size: 1.2rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.15em;
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .plan-price {
            font-size: 4rem;
            font-weight: 800;
            color: var(--accent-green);
            font-family: 'JetBrains Mono', monospace;
            margin-bottom: 0.5rem;
            line-height: 1;
        }

        .plan-currency {
            font-size: 1.5rem;
            color: var(--text-secondary);
            font-weight: 400;
        }

        .pricing-toggle-container {
            margin: 2rem 0;
        }

        .pricing-toggle {
            display: flex;
            gap: 0;
            background: rgba(0, 191, 99, 0.05);
            border-radius: 8px;
            padding: 4px;
            margin-bottom: 1.5rem;
        }

        .toggle-btn {
            flex: 1;
            padding: 0.8rem 1.5rem;
            background: transparent;
            border: none;
            color: var(--text-secondary);
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 6px;
            font-family: 'Outfit', sans-serif;
        }

        .toggle-btn.active {
            background: var(--accent-green);
            color: var(--bg-dark);
            box-shadow: 0 4px 12px var(--accent-green-glow);
        }

        .toggle-btn:hover:not(.active) {
            background: rgba(0, 191, 99, 0.1);
            color: var(--accent-green);
        }

        .pricing-display {
            text-align: center;
            padding: 1.5rem;
            background: rgba(0, 191, 99, 0.08);
            border: 2px solid rgba(0, 191, 99, 0.3);
            border-radius: 12px;
            margin-bottom: 1rem;
        }

        .price-amount {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--accent-green);
            font-family: 'JetBrains Mono', monospace;
            display: block;
            margin-bottom: 0.5rem;
        }

        .price-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
            display: block;
            font-weight: 500;
        }

        .plan-features {
            list-style: none;
            margin: 2.5rem 0;
        }

        .plan-features li {
            padding: 0.8rem 0;
            color: var(--text-secondary);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .plan-features li:last-child {
            border-bottom: none;
        }

        .plan-features li::before {
            content: '✓';
            color: var(--accent-green);
            font-weight: 800;
            margin-right: 1rem;
            font-size: 1.2rem;
            flex-shrink: 0;
        }

        .feature-label {
            color: var(--text-secondary);
        }

        .feature-value {
            color: var(--accent-green);
            font-weight: 700;
            font-family: 'JetBrains Mono', monospace;
            margin-left: auto;
        }

        .plan-button {
            display: block;
            width: 100%;
            padding: 1.2rem;
            background: transparent;
            border: 2px solid var(--accent-green);
            color: var(--accent-green);
            font-weight: 700;
            font-size: 1rem;
            text-align: center;
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-family: 'Outfit', sans-serif;
            cursor: not-allowed;
            opacity: 0.8;
        }

        .plan-button:disabled {
            cursor: not-allowed;
        }

        .btn-countdown {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
        }

        .pricing-card.featured .plan-button {
            background: var(--accent-green);
            color: var(--bg-dark);
            opacity: 1;
        }

        /* Custom Funding Section */
        .custom-funding {
            position: relative;
            z-index: 10;
            padding: 8rem 5%;
            background: linear-gradient(180deg, transparent, rgba(0, 191, 99, 0.02), transparent);
        }

        .custom-funding-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .custom-funding-text h2 {
            text-align: left;
            margin-bottom: 1.5rem;
        }

        .custom-funding-description {
            font-size: 1.15rem;
            line-height: 1.8;
            color: var(--text-secondary);
            margin-bottom: 2.5rem;
        }

        .custom-funding-description strong {
            color: var(--accent-green);
            font-weight: 800;
            font-size: 1.3rem;
        }

        .custom-features {
            list-style: none;
            margin-bottom: 3rem;
        }

        .custom-features li {
            padding: 1rem 0;
            color: var(--text-primary);
            font-size: 1.1rem;
            display: flex;
            align-items: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .custom-features li::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--accent-green);
            border-radius: 50%;
            margin-right: 1.5rem;
            flex-shrink: 0;
        }

        .custom-button {
            display: inline-block;
            padding: 1.3rem 3rem;
            background: var(--accent-green);
            color: var(--bg-dark);
            font-weight: 700;
            font-size: 1.1rem;
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 10px 40px var(--accent-green-glow);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .custom-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 50px rgba(0, 191, 99, 0.4);
        }

        .custom-funding-visual {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .custom-card {
            background: var(--bg-card);
            border: 2px solid var(--accent-green);
            border-radius: 20px;
            padding: 4rem 3rem;
            text-align: center;
            box-shadow: 0 20px 60px rgba(0, 191, 99, 0.2);
            transition: all 0.4s ease;
        }

        .custom-card:hover {
            transform: translateY(-10px) scale(1.05);
            box-shadow: 0 30px 80px rgba(0, 191, 99, 0.3);
        }

        .custom-icon {
            width: 100px;
            height: 100px;
            background: rgba(0, 191, 99, 0.1);
            border: 2px solid var(--accent-green);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 2rem;
        }

        .custom-icon svg {
            width: 50px;
            height: 50px;
            color: var(--accent-green);
        }

        .custom-amount {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--accent-green);
            font-family: 'JetBrains Mono', monospace;
            margin-bottom: 1rem;
            line-height: 1;
        }

        .custom-label {
            color: var(--text-secondary);
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 600;
        }

        /* Footer */
        footer {
            position: relative;
            z-index: 10;
            padding: 3rem 5%;
            border-top: 1px solid rgba(0, 191, 99, 0.1);
            text-align: center;
            color: var(--text-secondary);
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .trust-indicators {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            body {
                font-size: 16px;
            }

            .hero h1 {
                font-size: 3rem;
            }

            .hero p {
                font-size: 1.1rem;
            }

            .countdown-timer {
                gap: 1rem;
            }

            .countdown-item {
                padding: 1rem 1.2rem;
                min-width: 70px;
            }

            .countdown-number {
                font-size: 2.5rem;
            }

            .countdown-text {
                font-size: 0.7rem;
            }

            .section-title {
                font-size: 2.5rem;
            }

            nav {
                gap: 1rem;
